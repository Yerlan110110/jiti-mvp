# Server
PORT=3000
NODE_ENV=development

# JWT — ОБЯЗАТЕЛЬНО сменить в production!
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d

# SMS
SMS_MOCK=true
SMS_MOCK_CODE=1234

# Database (PostgreSQL for production, leave empty for local SQLite)
# DATABASE_URL=postgresql://user:password@host:5432/jiti

# CORS — разрешённые домены через запятую
CORS_ORIGINS=http://localhost:3000

# Admin — телефон первого администратора
ADMIN_PHONE=+77001234567
